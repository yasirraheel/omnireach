# XSender WhatsApp Service - Configuration
# Most settings are managed from Laravel via API
#
# AUTO-SYNC: The API key is automatically read from Laravel's .env file.
# You do NOT need to manually set API_KEY here unless you want to override it.

# Server Configuration
NODE_ENV=production

# For cPanel users - use these:
PORT=3001
HOST=127.0.0.1

# For VPS users - use these (also works):
# SERVER_PORT=3001
# SERVER_HOST=0.0.0.0

# ==========================================================
# Laravel Integration (Auto-Sync)
# ==========================================================
# Path to Laravel's .env file. The Node service reads WP_API_KEY
# and other settings directly from Laravel, so you only need to
# manage ONE .env file (Laravel's).
#
# Default: ../src/.env (standard directory structure)
# For cPanel: adjust to your Laravel app's .env location
# Example: /home/username/public_html/.env
LARAVEL_ENV_PATH=

# API Key (Optional Override)
# Leave empty to auto-read from Laravel's WP_API_KEY (recommended)
# Only set this if Node runs on a separate server from Laravel
API_KEY=

# Rate Limiting
RATE_LIMIT_WINDOW=60000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=info
LOG_PRETTY=false

# ==========================================================
# Connection Stability Settings (Prevents 10-15 min disconnect)
# ==========================================================

# Keep-alive interval in milliseconds (default: 20000 = 20 seconds)
# Lower = more stable but uses more bandwidth
# Recommended: 15000-25000 for shared hosting
KEEPALIVE_INTERVAL=20000

# Presence update interval in milliseconds (default: 300000 = 5 minutes)
# Sends "available" status to WhatsApp to prevent idle timeout
# Lower = more stable but may trigger anti-spam
PRESENCE_UPDATE_INTERVAL=300000

# Max reconnection attempts before giving up
MAX_RETRIES=10

# Delay between reconnection attempts in milliseconds
RECONNECT_INTERVAL=3000

# Query timeout in milliseconds (default: 30000 = 30 seconds)
QUERY_TIMEOUT=30000

# ==========================================================
# Memory Optimization for Shared Hosting (cPanel)
# ==========================================================

# Disables WebAssembly in HTTP client to prevent "Out of memory" errors
# when sending media files on memory-limited servers
UNDICI_NO_WASM=1

# cPanel Deployment Note:
# If using cPanel's Node.js Application, set SERVER_PORT to the port
# assigned by cPanel (usually shown in the application setup page).
# Do NOT use port 2083 (cPanel WHM SSL) or 2082 (cPanel HTTP).
 