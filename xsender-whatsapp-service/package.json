{
  "name": "xsender-whatsapp-service",
  "version": "2.1.0",
  "description": "Enterprise WhatsApp Service for XSender - Powered by Baileys with Message Queue, Health Monitoring & Graceful Shutdown",
  "main": "src/app.js",
  "type": "module",
  "engines": {
    "node": ">=18.0.0 <22.0.0",
    "npm": ">=9.0.0"
  },
  "scripts": {
    "start": "node --max-old-space-size=256 --expose-gc src/app.js",
    "start:cpanel": "node --max-old-space-size=256 --optimize-for-size --expose-gc src/app.js",
    "dev": "nodemon src/app.js",
    "pm2:start": "pm2 start ecosystem.config.cjs",
    "pm2:stop": "pm2 stop ecosystem.config.cjs",
    "pm2:restart": "pm2 restart ecosystem.config.cjs",
    "pm2:delete": "pm2 delete ecosystem.config.cjs",
    "pm2:logs": "pm2 logs xsender-whatsapp",
    "postinstall": "echo 'Installation complete'",
    "test": "echo \"Tests coming soon\" && exit 0"
  },
  "keywords": [
    "whatsapp",
    "baileys",
    "xsender",
    "whatsapp-api",
    "whatsapp-bot",
    "multi-device"
  ],
  "author": "XSender Team",
  "license": "UNLICENSED",
  "private": true,
  "dependencies": {
    "@whiskeysockets/baileys": "^6.7.21",
    "express": "^4.19.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "pino": "^9.5.0",
    "pino-pretty": "^11.3.0",
    "qrcode": "^1.5.4",
    "axios": "^1.7.7",
    "express-rate-limit": "^7.4.1",
    "helmet": "^8.0.0",
    "express-validator": "^7.2.0",
    "multer": "^1.4.5-lts.1",
    "sharp": "^0.33.5",
    "file-type": "^19.6.0",
    "nanoid": "^5.0.8",
    "node-cleanup": "^2.1.2",
    "compression": "^1.7.4"
  },
  "devDependencies": {
    "nodemon": "^3.1.7"
  }
}
